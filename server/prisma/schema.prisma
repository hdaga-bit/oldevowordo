generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Basic identity
  email         String?  @unique
  username      String?  @unique
  displayName   String?
  avatarUrl     String?
  // Optional external identities (fill later)
  authProvider  String?   // 'replit' | 'supabase' | 'clerk' | 'authjs' | 'dev'
  authExternalId String?  @unique

  // Anonymous support (mobile first-run)
  deviceId      String? @unique
  isAnonymous   Boolean  @default(true)
  
  // Account linking/migration support
  mergedIntoUserId String? // If this account was merged into another, store the target user ID
  mergedAt         DateTime? // When the merge happened

  // Profile customisation
  profileAvatar String?   // preset avatar key, e.g. "cat", "robot", "flame"
  profileColour String?   // hex accent colour, e.g. "#8b5cf6"

  // Game stats (denorm hints; keep truth in result tables)
  totalWins     Int      @default(0)
  totalGames    Int      @default(0)
  streak        Int      @default(0)
  longestStreak Int      @default(0)

  // Daily skill leaderboards (from won DailyResult rows)
  bestSolveAttempts  Int?
  avgSolveAttempts   Float?
  avgEfficiencyScore Float?

  // Account progression
  xp                 Int   @default(0)
  level              Int   @default(1)
  unlockedCosmetics  Json  @default("[]")
  equippedCosmetics  Json?

  results            DailyResult[]
  events             Event[]
  sessions           Session[]
  achievements       UserAchievement[]
  feedback           Feedback[]
  eventParticipations EventParticipation[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  meta          Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model WordLexicon {
  id     Int     @id @default(autoincrement())
  word   String  @unique
  length Int
  active Boolean @default(true)

  @@index([length, active])
}

/// One "daily" row per date. `seed` is the method to derive the word deterministically.
model DailyPuzzle {
  id         String        @id @default(cuid())
  date       String        @unique
  word       String
  createdAt  DateTime      @default(now())
  locked     Boolean       @default(false)
  checksum   String?
  difficulty String        @default("medium")
  results    DailyResult[]
}

/// One row per user per daily.
model DailyResult {
  id          String      @id @default(cuid())
  userId      String
  puzzleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// gameplay data
  guesses      Json     // list of guessed words (stored as JSON array)
  patterns     Json     // list of patterns (arrays of color strings, stored as JSON)
  attempts     Int      // 1..6 ; NULL => DNF
  won          Boolean  // true if solved
  completed    Boolean  @default(false) // true if game is over
  completedAt  DateTime? // when completed
  solved       Boolean  // true if solved (same as won)
  durationMs   Int?     // optional
  hardMode     Boolean  @default(false)
  efficiencyScore Int? // tile-weighted score for this puzzle (wins only)

  /// anti-cheat hints (optional)
  submittedIp String?
  userAgent   String?
  clientBuild String?
  
  puzzle      DailyPuzzle @relation(fields: [puzzleId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([userId, puzzleId])
  @@index([puzzleId, attempts, won])
}

/// Simple append-only analytics stream.
model Event {
  id     String   @id @default(cuid())
  userId String?
  type   String
  ts     DateTime @default(now())
  roomId String?
  meta   Json?
  user   User?    @relation(fields: [userId], references: [id])

  @@index([type, ts])
  @@index([roomId, ts])
}

/// Session tracking for both anonymous and authenticated users
model Session {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String?  // Browser/device identifier
  token       String   @unique // Session token for client
  isAnonymous Boolean  @default(true)
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  
  // Connection metadata
  userAgent   String?
  ipAddress   String?
  
  user        User     @relation(fields: [userId], references: [id])
  
  @@index([userId, expiresAt])
  @@index([token, expiresAt])
  @@index([deviceId])
}

/// User-submitted feedback and improvement suggestions.
model Feedback {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String?
  category     String
  message      String
  contactEmail String?
  pageUrl      String?
  userAgent    String?
  status       String   @default("new")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, createdAt])
}

/// Admin-configurable live events (distinct from analytics Event).
model ScheduledEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  name         String
  eventKey     String   @unique
  mode         String
  scheduleSlot String
  timezone     String   @default("UTC")
  description  String?
  isActive     Boolean  @default(false)
  featured     Boolean  @default(true)

  status              String    @default("draft")
  enabled             Boolean   @default(true)
  startsAt            DateTime?
  durationMinutes     Int       @default(60)
  endsAt              DateTime?
  recurrenceRule      String?
  recurrenceTimezone  String    @default("UTC")
  lastRunAt           DateTime?
  nextRunAt           DateTime?
  rules               Json?
  theme               Json?
  rewards             Json?
  metadata            Json?
  disabledAt          DateTime?
  deletedAt           DateTime?
  createdByUserId     String?
  updatedByUserId     String?

  runs EventRun[]

  @@index([isActive])
  @@index([enabled, status])
  @@index([nextRunAt])
  @@index([mode, status])
}

/// One concrete execution of a scheduled live-ops event.
model EventRun {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  scheduledEventId String
  eventKey         String
  mode             String
  status           String    @default("live")
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  plannedEndAt     DateTime
  endedReason      String?
  roomId           String?
  rulesSnapshot    Json?
  themeSnapshot    Json?
  rewardsSnapshot  Json?
  metadata         Json?

  uniqueParticipants   Int   @default(0)
  peakConcurrentPlayers Int  @default(0)
  matchCount            Int  @default(0)
  completedMatchCount   Int @default(0)
  avgSessionDurationMs  Int?

  scheduledEvent ScheduledEvent @relation(fields: [scheduledEventId], references: [id], onDelete: Cascade)
  participations EventParticipation[]

  @@index([status, startedAt])
  @@index([eventKey, startedAt])
  @@index([scheduledEventId, startedAt])
  @@index([roomId])
}

/// Per-player participation and session stats for event runs.
model EventParticipation {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  eventRunId          String
  userId              String?
  playerId            String?
  roomId              String?
  displayNameSnapshot String?
  joinedAt            DateTime  @default(now())
  leftAt              DateTime?
  sessionDurationMs   Int?
  matchesPlayed       Int       @default(0)
  wins                Int       @default(0)
  losses              Int       @default(0)
  disconnects         Int       @default(0)
  lastActiveAt        DateTime  @default(now())
  meta                Json?

  eventRun EventRun @relation(fields: [eventRunId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventRunId, playerId])
  @@index([eventRunId, lastActiveAt])
  @@index([userId, joinedAt])
  @@index([roomId])
}
